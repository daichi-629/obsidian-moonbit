{
	"name": "obsidian-moonbit",
	"version": "0.0.1",
	"packageManager": "pnpm@10.14.0",
	"type": "module",
	"main": "dist/runtime.js",
	"types": "dist/runtime.d.ts",
	"exports": {
		".": {
			"types": "./dist/runtime.d.ts",
			"default": "./dist/runtime.js"
		},
		"./obsidian-api": {
			"types": "./dist/obsidian-api.d.ts",
			"default": "./dist/obsidian-api.js"
		},
		"./esbuild-plugin": {
			"types": "./dist/esbuild-plugin.d.ts",
			"default": "./dist/esbuild-plugin.js"
		}
	},
	"files": ["dist", "README.md", "LICENSE"],
	"publishConfig": {
		"access": "public"
	},
	"workspaces": ["packages/*"],
	"scripts": {
		"build:packages": "npm run build --workspaces --if-present",
		"build": "npm run build:packages && node ./scripts/build-github-package.mjs",
		"dev": "npm run dev --workspaces --if-present",
		"lint": "npm run lint --workspaces --if-present",
		"test": "npm run test --workspaces --if-present",
		"format": "prettier -w .",
		"format:check": "prettier -c .",
		"typecheck": "npm run build --workspaces --if-present",
		"prepare": "npm run build"
	},
	"devDependencies": {
		"@types/node": "^25.2.2",
		"esbuild": "^0.27.3",
		"eslint": "^9.39.2",
		"prettier": "^3.8.1",
		"typescript": "^5.5.4"
	}
}
